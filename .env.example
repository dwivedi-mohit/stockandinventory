# MySQL Database Configuration (local development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=inventory_db

# On Railway, the MySQL plugin provides these automatically (referenced by the app):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

# Application
APP_TITLE=Inventory Management System
APP_COMPANY=Your Company Name

# Session cookie signing secret (set a long random value in production)
STORAGE_SECRET=change-me-to-a-long-random-string
